{
  "name": "@hivehook/sdk",
  "version": "0.1.0",
  "description": "Official Hivehook TypeScript SDK",
  "keywords": ["hivehook", "webhook", "webhooks", "graphql", "sdk"],
  "homepage": "https://hivehook.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hivehook/sdk-typescript.git"
  },
  "bugs": {
    "url": "https://github.com/hivehook/sdk-typescript/issues"
  },
  "author": "Hivehook",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./webhook": {
      "types": "./dist/webhook/index.d.ts",
      "import": "./dist/webhook/index.js",
      "require": "./dist/webhook/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  }
}
